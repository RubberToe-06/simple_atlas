{
	"schemaVersion": 1,
	"id": "simple-atlas",
	"version": "${version}",
	"name": "Simple Atlas",
	"description": "Adds a no-nonsense Vanilla+ atlas for all your mapping needs.",
	"authors": [
		"RubberToe"
	],
	"contact": {
		"sources": "https://github.com/RubberToe-06/simple_atlas"
	},
	"license": "MIT",
	"icon": "assets/simple-atlas/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"rubbertoe.simple_atlas.SimpleAtlas"
		],
		"client": [
			"rubbertoe.simple_atlas.client.SimpleAtlasClient"
		],
		"fabric-datagen": [
          "rubbertoe.simple_atlas.datagen.SimpleAtlasDataGenerator"
		]
	},
	"mixins": [
		"simple-atlas.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}
